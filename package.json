{
  "name": "md2wechat",
  "displayName": "MD Export - Markdown 导出微信/知乎/小红书",
  "description": "将 Markdown 一键导出到微信公众号/知乎/小红书，支持 LaTeX 公式、10 套主题、实时预览、小红书截图导出",
  "version": "1.9.2",
  "publisher": "marsggbo",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#2d7a3e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "keywords": [
    "markdown",
    "wechat",
    "微信公众号",
    "小红书",
    "知乎",
    "公式",
    "LaTeX",
    "KaTeX",
    "preview",
    "export"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marsggbo/md2wechat"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:md2wechat.preview",
    "onCommand:md2wechat.convert"
  ],
  "contributes": {
    "commands": [
      {
        "command": "md2wechat.preview",
        "title": "预览微信公众号效果",
        "category": "md2wechat",
        "icon": "$(open-preview)"
      },
      {
        "command": "md2wechat.convert",
        "title": "导出微信公众号 HTML 文件",
        "category": "md2wechat",
        "icon": "$(export)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "md2wechat.preview",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "md2wechat.preview",
          "when": "resourceExtname == .md",
          "group": "1_modification"
        },
        {
          "command": "md2wechat.convert",
          "when": "resourceExtname == .md",
          "group": "1_modification"
        }
      ],
      "editor/context": [
        {
          "command": "md2wechat.preview",
          "when": "resourceLangId == markdown",
          "group": "1_modification"
        }
      ]
    },
    "keybindings": [
      {
        "command": "md2wechat.preview",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "resourceLangId == markdown"
      }
    ],
    "configuration": {
      "title": "MD2WeChat",
      "properties": {
        "md2wechat.appid": {
          "type": "string",
          "default": "",
          "description": "微信公众号 AppID（用于上传草稿箱，通过 FastPen 服务）"
        },
        "md2wechat.appSecret": {
          "type": "string",
          "default": "",
          "description": "微信公众号 AppSecret（用于上传草稿箱，通过 FastPen 服务）"
        },
        "md2wechat.author": {
          "type": "string",
          "default": "",
          "description": "默认作者名称"
        },
        "md2wechat.digest": {
          "type": "string",
          "default": "",
          "description": "默认文章摘要"
        },
        "md2wechat.template": {
          "type": "string",
          "default": "wechat",
          "description": "模板名称（可在工作区 templates/ 目录下放置同名 .html 模板）"
        },
        "md2wechat.outputPath": {
          "type": "string",
          "default": "build",
          "description": "导出 HTML 的目录（相对于工作区根目录）"
        }
      }
    }
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.9.0",
    "html2canvas": "^1.4.1",
    "juice": "^9.1.0",
    "katex": "^0.16.0",
    "marked": "^11.1.1",
    "mathjax-full": "^3.2.1",
    "playwright-core": "^1.59.1",
    "pngjs": "^7.0.0"
  },
  "scripts": {
    "package": "vsce package",
    "install-ext": "vsce package && \"/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code\" --install-extension \"md2wechat-$(node -p \"require('./package.json').version\").vsix\"",
    "publish": "vsce publish",
    "start:electron": "electron ./electron/main.js",
    "build:mac": "electron-builder --mac",
    "build:mac:universal": "electron-builder --mac --universal"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
